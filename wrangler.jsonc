{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "spidertypes",
  "compatibility_date": "2026-06-29",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "spidertypes.com",
      "custom_domain": true
    },
    {
      "pattern": "www.spidertypes.com",
      "custom_domain": true
    }
  ]
}
